{
  "name": "bedrock-agentic-log-analysis",
  "version": "1.0.0",
  "description": "Production AWS Bedrock agentic log-analysis system: multi-agent CloudWatch/Splunk/generic-log/email-alert analysis orchestrated via Bedrock Flows, with alerting and SES email reports.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --test --import tsx test/severity.test.ts test/report.test.ts test/flow.test.ts",
    "clean": "rimraf dist",
    "package": "npm run clean && npm run build",
    "tf:fmt": "terraform -chdir=infra fmt -recursive",
    "tf:init": "terraform -chdir=infra init",
    "tf:validate": "terraform -chdir=infra validate",
    "tf:plan": "terraform -chdir=infra plan",
    "tf:apply": "terraform -chdir=infra apply",
    "deploy": "npm run package && npm run tf:apply"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent": "^3.700.0",
    "@aws-sdk/client-bedrock-agent-runtime": "^3.700.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@aws-sdk/client-sns": "^3.700.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.14.0",
    "esbuild": "^0.23.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
