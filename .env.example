# Copy to .env for local handler testing (not used by deployed Lambdas — those
# get their config from Terraform-managed environment variables).
AWS_REGION=us-east-1

# Splunk connection (the Splunk action-group Lambda reads these from Secrets
# Manager in production; these are for local dev only).
SPLUNK_HOST=https://splunk.example.com:8089
SPLUNK_TOKEN=changeme

# SES verified sender + default recipients for report/alert dispatch.
REPORT_SENDER=log-analysis@example.com
REPORT_RECIPIENTS=oncall@example.com,platform-team@example.com
