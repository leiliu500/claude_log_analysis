# Copy to terraform.tfvars and edit.

aws_region  = "us-gov-west-1"
name_prefix = "logai"

# Must be enabled in Bedrock -> Model access for this account/region AND supported by
# Bedrock Agents/Flows. Verify with:
#   aws bedrock list-foundation-models --region us-gov-west-1 --query "modelSummaries[].modelId"
foundation_model = "openai.gpt-oss-120b-1:0"

# SES: the sender must be a verified identity (confirm the verification email).
report_sender     = "log-analysis@example.com"
report_recipients = ["oncall@example.com", "platform-team@example.com"]

# Alerting
alert_threshold           = "high"
alert_email_subscriptions = ["oncall@example.com"]

# CloudWatch agent default scan targets (optional; agent can also be told explicitly).
default_log_groups = [
  "/aws/lambda/my-service",
  "/ecs/my-cluster/my-app",
]

# Splunk (optional). Create the secret first, e.g.:
#   aws secretsmanager create-secret --name logai/splunk \
#     --secret-string '{"host":"https://splunk.example.com:8089","token":"<token>"}'
splunk_secret_arn = ""

# Scheduling
schedule_expression = "rate(1 hour)"
window_minutes      = 60
enable_schedule     = true

# Flow (requires AWS provider >= 5.83). Set false to deploy agents/Lambdas only.
enable_flow = true

# Optional SES inbound receipt (only in us-east-1 / us-west-2 / eu-west-1).
enable_ses_inbound     = false
ses_inbound_recipients = []
email_prefix           = ""
